<?xml version="1.0" encoding="UTF-8"?>

<!-- indica al template que respete los espacios en blanco (saltos de pagina y espacios) -->
<templates xml:space="preserve">

    <!-- la etiqueta "t" indica una plantilla o template -->
    <t t-name="awesome_owl.Playground">
        <div class="container p-3 border">
            <p>
                Counter: <t t-esc="state.value"/>
            </p>
            <button type="button" class="btn btn-primary" t-on-click="increment">Increment</button>
        </div>
    </t>

</templates>